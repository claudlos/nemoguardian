# Paste your customer API key from /billing/welcome here.
# In self-hosted Docker, this also bootstraps /v1/moderate auth without a pre-seeded DB row.
# Placeholder values like this are rejected; use a real nmg_... key for demos.
NEMOGUARDIAN_API_KEY=nmg_paste_your_key_here
NEMOGUARDIAN_SELF_HOSTED_EMAIL=self-hosted@nemoguardian.local

# Optional — only used if you want to forward usage events back to our billing.
STRIPE_CUSTOMER_ID=

# Optional — enables real Nemotron 3 Ultra triage in deep mode.
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
NEMOGUARDIAN_TRIAGE_BASE_URL=

# Cascade tuning for the Vast.ai RTX 3090 demo.
NEMOGUARDIAN_TIER=self_hosted
NEMOGUARDIAN_CASCADE_MODE=standard
NEMOGUARDIAN_QUANTIZE=1
NEMOGUARDIAN_QWEN_MODEL=Qwen/Qwen3Guard-Gen-4B
NEMOGUARDIAN_QWEN_STREAM_MODEL=Qwen/Qwen3Guard-Stream-0.6B
NEMOGUARDIAN_CSR_MODEL=nvidia/Nemotron-Content-Safety-Reasoning-4B
NEMOGUARDIAN_TRIAGE_MODEL=nvidia/nemotron-3-ultra-550b-a55b
# Enable only for a controlled demo host. Keep disabled on internet-facing deployments.
NEMOGUARDIAN_ENABLE_DEMO_ENDPOINT=0

# Optional local-only escape hatch for unsigned Stripe webhook fixture payloads.
# Never enable on an internet-facing deployment.
NEMOGUARDIAN_INSECURE_WEBHOOK_DEMO=0

# Discord moderation bot. Keep the token out of git.
# Required Discord app setup:
# - OAuth scopes: bot, applications.commands
# - Bot permissions: View Channel, Read Message History, Send Messages, Embed Links,
#   Manage Messages, Moderate Members
# - Gateway intents: Guilds, Guild Messages, Message Content
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
NEMOGUARDIAN_BOT_CONFIG_PATH=/tmp/nemoguardian_bot_config.json
NEMOGUARDIAN_BOT_AUDIT_PATH=/tmp/nemoguardian_bot_audit.jsonl
